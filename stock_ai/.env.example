# ============================================================
# KRX OpenAPI 인증키 (★ 권장 — OHLCV/시총/유니버스 수집에 사용)
# ============================================================
# 1. https://openapi.krx.co.kr 접속 → 로그인 → 인증키 신청
# 2. MyPage → 사용할 API '활용신청' → 승인 (보통 1일 내, 이메일 통지)
#      · 유가증권 일별매매정보 (sto/stk_bydd_trd)
#      · 코스닥 일별매매정보   (sto/ksq_bydd_trd)
# 3. 발급받은 인증키를 아래에 입력
KRX_AUTH_KEY=여기에_KRX_OpenAPI_인증키_입력

# ── (레거시) KRX 사이트 로그인 ID/PW ──
# data.krx.co.kr 일반 회원가입 방식. 카톡 등 소셜 로그인이면 없을 수 있음.
# KRX_AUTH_KEY 가 있으면 비워둬도 됨.
KRX_ID=
KRX_PW=

# ============================================================
# DART (전자공시시스템) API 키 — 재무제표 수집
# ============================================================
# 발급: https://opendart.fss.or.kr → 회원가입 → 인증키 신청
DART_API_KEY=여기에_DART_키_입력

# ============================================================
# OpenAI API 키 — 멀티모달 분석(뉴스 감성·밸류에이션·LLM 내러티브)
# ============================================================
# 발급: https://platform.openai.com/api-keys
# 없어도 시스템은 동작함 (해당 모달리티는 자동 비활성/템플릿 fallback)
OPENAI_API_KEY=여기에_OPENAI_키_입력

# ============================================================
# NewsAPI 키 — 뉴스 감성 모달리티 (선택)
# ============================================================
# 발급: https://newsapi.org/register
# 없으면 뉴스 모달리티만 제외되고 나머지로 분석 진행
NEWSAPI_KEY=여기에_NEWSAPI_키_입력
